{
  "expo": {
    "name": "Activistem!",
    "slug": "activistem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "activistem",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.activistem.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080714",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.activistem.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "投稿に画像を添付するためにフォトライブラリへのアクセスを許可してください。"
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c475f78a-b593-4b90-b76e-16b11ed4ce6f"
      }
    }
  }
}
